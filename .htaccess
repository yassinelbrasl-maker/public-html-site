# ─────────────────────────────────────────────────────────────────────
#   Cortoba Architecture Studio — .htaccess APEX (post-bascule SPA React)
#
#   Servir la version React + prerender HTML pour les crawlers + SPA
#   fallback pour les routes non-prerenderées.
#
#   Rollback : `git checkout pre-spa-switch-20260423 -- .` (tag créé)
# ─────────────────────────────────────────────────────────────────────

Options -Indexes
DirectoryIndex index.html

<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
  # Assets hashés par Vite : cache long
  <FilesMatch "assets/.+\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── 301 redirects de l'ancien format .html vers les nouvelles URLs ──
  # Préservent le SEO acquis sur ces URLs
  RewriteRule ^landscaping\.html$        /landscaping       [R=301,L]
  RewriteRule ^configurateur\.html$      /configurateur     [R=301,L]
  RewriteRule ^settings\.html$           /settings          [R=301,L]

  # ── L'API PHP reste servie tel quel (ne pas intercepter) ──
  RewriteRule ^cortoba-plateforme/api/ - [L]

  # ── Blocage direct du scaffold React (source) et du backup legacy ──
  RedirectMatch 403 ^/cortoba-react/
  RedirectMatch 403 ^/_legacy/

  # ── Fichiers statiques existants (assets, images, fonts…) : passer ──
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── Route prerenderée ? Servir <route>/index.html si le dossier existe ──
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]

  # ── SPA fallback : tout le reste → index.html (React Router prend le relais) ──
  RewriteRule ^ index.html [L]
</IfModule>
