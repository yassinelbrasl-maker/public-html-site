{
  "name": "cortoba-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Full React + TypeScript rewrite of cortobaarchitecture.com (Option C). Not yet live.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender-seo.mjs && node scripts/generate-sitemap.mjs",
    "build:nose": "tsc -b && vite build",
    "deploy": "npm run build && node scripts/copy-to-public.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.53.2",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
