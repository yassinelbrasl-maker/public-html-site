# TypeScript incremental build cache — regenerated each build
*.tsbuildinfo

# Playwright test artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
